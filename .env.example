# Google Search Console verification (copy the verification string from GSC → Settings → Ownership verification → HTML tag)
# The site already renders the meta tag — just set this value and deploy.
GOOGLE_SITE_VERIFICATION=

# Canonical site URL — local dev vs Vercel
# Locally: http://localhost:3003 (or your dev port)
# On Vercel: set Production + Preview env to https://<your-project>.vercel.app (and update when you attach a custom domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3003

# WhatsApp chat link (digits only, country code without +): e.g. 34600111222
NEXT_PUBLIC_WHATSAPP_PHONE=

NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=7pbe7nrp
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

